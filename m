-	       (shifter_st.bas_md & 0xff) << 8  |
-	       (shifter_st.bas_lo & 0xff);
-	par->screen_base = atari_stram_to_virt(addr);
-
-	/* derived parameters */
-	hw->ste_mode = (hw->f_shift & 0x510) == 0 && hw->st_shift == 0x100;
-	hw->mono = (hw->f_shift & 0x400) ||
-	           ((hw->f_shift & 0x510) == 0 && hw->st_shift == 0x200);
